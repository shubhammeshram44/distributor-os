# DistributorOS Environment Variables Configuration
# Copy to `.env` (backend) and configure frontend vars in `frontend/.env.local` or your deploy host.

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
DATABASE_URL=sqlite:///./distributor_os.db
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# -----------------------------------------------------------------------------
# Firebase Authentication (Backend — required for phone auth)
# -----------------------------------------------------------------------------
# Minified single-line JSON string of your Firebase service account credentials.
# Used by the Firebase Admin SDK to verify ID tokens from the client.
# Example: FIREBASE_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
FIREBASE_CREDENTIALS_JSON=

# -----------------------------------------------------------------------------
# Firebase Authentication (Frontend — set at build time)
# -----------------------------------------------------------------------------
# Create these in Firebase Console → Project Settings → Your apps → Web app config.
# Prefix with NEXT_PUBLIC_ so Next.js exposes them to the browser.
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_WEB_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Legacy SMS Provider (DEPRECATED for authentication)
# -----------------------------------------------------------------------------
# Phone OTP is now handled entirely by Firebase Phone Authentication.
# These variables are no longer used by /auth routes. They may remain for
# non-auth SMS features only; safe to omit for new deployments.
# SMS_PROVIDER=MSG91
# SMS_GATEWAY_API_KEY=YOUR_SMS_GATEWAY_API_KEY_HERE
